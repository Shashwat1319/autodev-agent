{
  "name": "autodev-agent",
  "version": "0.1.2",
  "description": "Auto-pilot your git. Auto-commits and pushes your code + analyzes your GitHub profile.",
  "main": "dist/index.js",
  "bin": {
    "autodev-agent": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "git",
    "auto-commit",
    "auto-push",
    "github",
    "portfolio",
    "automation",
    "developer-tools"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "watch": "ts-node-dev --respawn src/index.ts"
  },
  "dependencies": {
    "chokidar": "^3.6.0",
    "simple-git": "^3.24.0",
    "socket.io-client": "^4.7.5",
    "dotenv": "^16.4.5",
    "node-cron": "^3.0.3",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/autodev-agent.git"
  },
  "homepage": "https://github.com/your-username/autodev-agent",
  "license": "MIT"
}
