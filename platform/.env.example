# GitHub API token (required for 5000 req/hr rate limit)
GITHUB_TOKEN=ghp_your_token_here

# Razorpay live keys (for PDF report payments)
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Base URL (defaults to https://autodev-kappa.vercel.app)
NEXT_PUBLIC_BASE_URL=https://autodev-kappa.vercel.app
